{
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "notification-grouping": true,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "control-center-width": 420,
  "notification-window-width": 420,
  "relative-timestamps": true,
  "fit-to-screen": true,
  "hide-on-clear": false,
  "text-empty": "Sin notificaciones",
  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notificaciones",
      "clear-all-button": true,
      "button-text": "Borrar todo"
    },
    "dnd": {
      "text": "No molestar"
    }
  },
  "cssPriority": "user"
}
